# Build artifacts
/bin/
*.test
*.out
coverage.*

# Local config & secrets — never commit
/etc/faas/
*.local.toml
secrets/

# Firecracker / VM working state
/srv/fc/
*.ext4
*.snap
vmlinux-*

# Editor / OS
.DS_Store
.idea/
.vscode/

# Stray binaries at repo root from `make metal-lima` / local builds
# (Mach-O arm64 ~5MB). Distinct from guest/init/ and cmd/<daemon>/,
# which are the directories holding the actual source.
/init
/imaged
/builderd

# Stray binaries at repo root from `make metal-lima` / local guest-init
# build (cross-compiled for the Lima arm64 guest so the Dockerfile's
# `COPY guest-init` can stage it into builder-base). Distinct from
# guest/init/, which is the directory holding the source.
/guest-init
