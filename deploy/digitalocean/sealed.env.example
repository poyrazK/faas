# Copy to /etc/faas/sealed.env on the Droplet and fill in.
# This file is read by systemd EnvironmentFile= — one VAR=value per line.

# Postgres — default uses peer auth over Unix socket.
DATABASE_URL=postgres:///faas?host=/run/postgresql&user=faas

# Dev token for API testing (apid creates a dev account on first boot).
# Must match fp_live_<48-hex> format.
FAAS_DEV_TOKEN=fp_live_888888888888888888888888888888888888888888888888

# Public OCI image ref for builder base (since ghcr.io/onebox-faas/... is private).
# This satisfies imaged's startup check, even though we won't run VM builds.
# Must be pinned to a specific architecture digest (manifest lists not supported).
FAAS_BUILDER_BASE_REF=docker.io/library/alpine@sha256:79ff19e9084a00eece421b2523fb93e22d730e2c0e525905de047e848e56d95f

# Apps domain — set by bootstrap.sh.
FAAS_APPS_DOMAIN=__DROPLET_IP__.nip.io

# Session key for dashboard cookies (32-byte hex).
# Generate: openssl rand -hex 32
FAAS_SESSION_KEY=__SESSION_KEY__

# GitHub App (set after creating the app in github.com/settings/apps).
# FAAS_GITHUB_APP_ID=
# FAAS_GITHUB_APP_KEY_PATH=/etc/faas/secrets/github-app.pem
# FAAS_GITHUB_WEBHOOK_SECRET=

# Stripe (optional — skip for now).
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# apid extras.
FAAS_APID_LISTEN=0.0.0.0:8081
# FAAS_PROMETHEUS_URL=http://127.0.0.1:9090
# FAAS_HOST_AGE_RECIPIENT_PATH=/etc/faas/secrets/host.age.pub
