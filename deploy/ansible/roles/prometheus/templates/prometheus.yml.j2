# Prometheus scrape config (spec §12 dashboard pipeline).
# Generated by ansible — do not hand-edit on the box.

global:
  scrape_interval: 15s
  evaluation_interval: 15s
  external_labels:
    box: "{{ ansible_hostname }}"

scrape_configs:
{% for tgt in prom_targets %}
  - job_name: "{{ tgt.job }}"
    static_configs:
      - targets: ["{{ tgt.host }}:{{ tgt.port }}"]
        labels:
          job: "{{ tgt.job }}"
{% endfor %}