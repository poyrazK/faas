# Minimal Grafana config for the faas one-box. Generated by ansible;
# do not hand-edit on the box. Pairs with provisioning-datasources.yml.j2
# + provisioning-dashboards.yml.j2 — every [section] here stays
# minimal because file-based provisioning owns the datasource + dashboard
# surfaces (no admin-API import step).
#
# Admin password is read at process start from GF_SECURITY_ADMIN_PASSWORD__FILE
# (see files/grafana-server.service). The rendered file does NOT contain
# the password bytes; the path is the only thing that flows into the
# environment. Same precedent as the alertmanager *_file secrets
# (gap G2 lean §17, sealed at rest).

[paths]
data = {{ gv_data_dir }}
logs = /var/log/grafana
plugins = /var/lib/grafana/plugins
provisioning = {{ gv_provisioning_dir }}

[server]
http_addr = {{ gv_listen_addr.split(':')[0] }}
http_port = {{ gv_listen_addr.split(':')[1] }}

[security]
admin_user = admin
disable_gravatar = true

[analytics]
reporting_enabled = false
check_for_updates = false

[log]
mode = console
level = info

[users]
allow_sign_up = false
