# Alertmanager configuration — generated by ansible; do not hand-edit on the box.
#
# Severity → notification mapping (locked to deploy/ansible/roles/prometheus/files/faas.rules.yml):
#   info  → suppressed (no receiver; surfaces in Prometheus / Grafana only).
#   warn  → email ticket-only via faas-warn receiver.
#   page  → operator email + Pushover via faas-page receiver.
#
# Grouping: by alertname + component so a single fault (e.g. apid down)
# doesn't fan out into per-route email storms; group_wait 30s gives the
# first wave of firing alerts time to coalesce.

global:
  resolve_timeout: 5m

route:
  receiver: faas-page
  group_by: [alertname, component]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  routes:
    # page-severity: full notify (email + Pushover).
    - matchers:
        - severity = "page"
      receiver: faas-page
      group_wait: 10s
      repeat_interval: 1h
    # warn-severity: ticket-only email; longer repeat so we don't spam.
    - matchers:
        - severity = "warn"
      receiver: faas-warn
      repeat_interval: 4h
    # info-severity: no receiver — the matcher matches but no route fires.
    - matchers:
        - severity = "info"
      receiver: faas-silent
      continue: false

receivers:
  - name: faas-page
    email_configs:
      - to: "{{ am_email_to_page }}"
        from: "{{ am_email_from }}"
        smarthost: "127.0.0.1:25"
        # smtp_password loaded from am_smtp_password_file by the
        # tasks/main.yml loader. Secret material is never templated
        # into this file directly (gap G2 lean §17 — sealed at rest).
        smtp_auth_username: "{{ am_email_from }}"
        smtp_require_tls: false
        send_resolved: true
        headers:
          X-Faas-Alert: "page"
    pushover_configs:
      # token loaded from am_pushover_token_file by tasks/main.yml loader.
      - user_key: "{{ am_pushover_user }}"
        send_resolved: true
        priority: 2   # emergency: bypass quiet hours on the device
        retry: 60
        expire: 3600
        title: "faas page"
        url: "{{ ansible_default_ipv4.address | default('onebox') }}:9090/alerts"

  - name: faas-warn
    email_configs:
      - to: "{{ am_email_to_warn }}"
        from: "{{ am_email_from }}"
        smarthost: "127.0.0.1:25"
        smtp_auth_username: "{{ am_email_from }}"
        smtp_require_tls: false
        send_resolved: true
        headers:
          X-Faas-Alert: "warn"

  - name: faas-silent
    # No integration blocks. The route matches severity="info" but
    # resolves to this empty receiver, so info alerts are visible in
    # Prometheus / Grafana but never page anyone.

inhibit_rules:
  # A page supersedes a warn on the same alertname+component. Keeps
  # the inbox from getting two emails (one ticket, one page) for the
  # same fault when the warn-tier crosses the page-tier threshold.
  - source_matchers:
      - severity = "page"
    target_matchers:
      - severity = "warn"
    equal: [alertname, component]
